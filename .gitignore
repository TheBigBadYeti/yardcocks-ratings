# Raw Fantrax exports — committed weekly (swapped in place each refresh)
!data/raw/*.csv
!data/raw/.gitkeep

# Processed outputs — regenerated each run, not committed (snapshots go to data/history/)
data/processed/*.csv

# News — recent_moves.csv committed each refresh
!data/news/*.csv
!data/news/.gitkeep

# Recency — recent_fpg.csv committed each refresh
!data/recency/*.csv
!data/recency/.gitkeep

# Claude Code — machine-local settings stay off the repo
.claude/settings.local.json

# Python
.venv/
__pycache__/
*.pyc
