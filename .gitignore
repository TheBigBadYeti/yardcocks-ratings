# Raw Fantrax exports — committed weekly (swapped in place each refresh)
!data/raw/*.csv
!data/raw/.gitkeep

# Processed outputs — regenerated each run. Only the published ratings file is tracked
# (readers pull it via /sync); everything else in data/processed/ stays local. This
# includes the per-run handoff artifacts (e.g. lineup_recommendation.csv,
# lineup_needs.json) that /lineups writes for /waivers within the same session.
data/processed/*.csv
data/processed/*.json
!data/processed/current_player_ratings.csv

# News — recent_moves.csv committed each refresh
!data/news/*.csv
!data/news/.gitkeep

# Recency — recent_fpg.csv committed each refresh
!data/recency/*.csv
!data/recency/.gitkeep

# Claude Code — machine-local settings stay off the repo
.claude/settings.local.json

# Injuries — IL + returning (rehab) snapshots committed so cloud/phone readers get
# them. The writer needs MLB API access (cloud VMs are blocked), so a reader can't
# refetch; /lineups and /waivers read what an MLB-capable writer committed.
data/injuries/*
!data/injuries/il_status.csv
!data/injuries/returning.csv

# Python
.venv/
__pycache__/
*.pyc

# track the ratings output so cloud can read it directly
!data/processed/current_player_ratings.csv
