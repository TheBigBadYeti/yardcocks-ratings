# Raw Fantrax exports — committed weekly (swapped in place each refresh)
!data/raw/*.csv
!data/raw/.gitkeep

# Processed outputs — regenerated each run. Only the published ratings file is tracked
# (readers pull it via /sync); everything else in data/processed/ stays local.
# Match ALL extensions, not just *.csv: lineup_needs.json used to slip through and show
# as untracked on every read-only /lineups run, tripping the stop hook in reader sessions.
data/processed/*
!data/processed/current_player_ratings.csv

# News — recent_moves.csv committed each refresh
!data/news/*.csv
!data/news/.gitkeep

# Recency — recent_fpg.csv committed each refresh
!data/recency/*.csv
!data/recency/.gitkeep

# Claude Code — machine-local settings stay off the repo
.claude/settings.local.json

# Injuries — IL + returning (rehab) snapshots committed so every session reads the same
# data. A Claude cloud VM can't fetch them itself (sandbox egress allowlist, not MLB),
# but the daily GitHub Action keeps them current.
data/injuries/*
!data/injuries/il_status.csv
!data/injuries/returning.csv

# Python
.venv/
__pycache__/
*.pyc
