# Raw Fantrax exports — committed weekly (swapped in place each refresh)
!data/raw/*.csv
!data/raw/.gitkeep

# Processed outputs — ratings CSVs are committed; per-run review artifact is not
!data/processed/
data/processed/prospect_match_misses.csv

# News — recent_moves.csv committed each refresh
!data/news/*.csv
!data/news/.gitkeep

# Python
.venv/
__pycache__/
*.pyc
